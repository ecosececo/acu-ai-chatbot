# ── Database ───────────────────────────────
POSTGRES_DB=acu_chatbot
POSTGRES_USER=acu_user
POSTGRES_PASSWORD=acu_secret

# ── Django ─────────────────────────────────
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ── LLM Configuration ─────────────────────
LLM_MODEL=mistral
EMBEDDING_MODEL=nomic-embed-text
OLLAMA_BASE_URL=http://ollama:11434

# ── Redis ──────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Scraper Settings ──────────────────────
SCRAPE_DELAY=2.0
SCRAPE_MAX_PAGES=500
